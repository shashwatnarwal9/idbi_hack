# आय·AI local configuration. Copy to .env and adjust; .env is git-ignored.
# These defaults match the docker-compose serving-postgres service and are for
# LOCAL DEVELOPMENT ONLY — use real credentials management in any deployment.

# deployment environment tag, surfaced on /health (local | render)
AAYAI_ENV=local

# serving Postgres — either a full DSN (managed hosts inject this) OR the
# AAYAI_PG_* parts below. SERVING_DB_DSN wins when set.
# SERVING_DB_DSN=postgresql://user:pass@host:5432/dbname
AAYAI_PG_HOST=localhost
AAYAI_PG_PORT=5433
AAYAI_PG_USER=aayai
AAYAI_PG_PASSWORD=aayai
AAYAI_PG_DB=aayai

# API (aayai.api) — allowed browser origin(s), comma-separated.
# In production set this to the deployed frontend URL.
AAYAI_CORS_ORIGIN=http://localhost:5173

# Airflow REST API (pipeline-state endpoint); local-dev credentials only
AAYAI_AIRFLOW_BASE_URL=http://localhost:8080
AAYAI_AIRFLOW_USERNAME=admin
AAYAI_AIRFLOW_PASSWORD=admin

# project root override, used when the pipeline runs inside a container
# AAYAI_ROOT=/opt/aayai
