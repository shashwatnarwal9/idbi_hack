# Copy to .env.production (git-ignored) for a local production build, or set
# VITE_API_BASE_URL as a build-time env var on the static-site host (Render).
# It must point at the deployed FastAPI URL; there is no runtime fallback in
# production, so an unset value would leave the app calling localhost.
VITE_API_BASE_URL=https://your-aayai-api.onrender.com
