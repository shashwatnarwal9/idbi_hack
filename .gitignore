# --- secrets: never tracked -------------------------------------------------
.env
.env.*
!.env.example
!frontend/.env.development
!frontend/.env.production.example
*.key
*.pem
*credentials*
.aws/
aws.config

# --- data: generated/real data never belongs in git -------------------------
# reproduce locally with: python -m aayai.datagen (seeded, deterministic)
# anchored to the repo root for the same reason as /model/ below
/data/
*.csv
*.parquet

# --- model artifacts ---------------------------------------------------------
# anchored to the repo root so this never shadows src/aayai/model (source code)
/model/
*.ubj
*.joblib
*.pkl

# --- python cruft ------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- local infra state (can embed secrets — never push) ----------------------
*.tfstate
*.tfstate.backup
.terraform/
airflow/logs/
*.log

# --- frontend ----------------------------------------------------------------
node_modules/
frontend/dist/

# --- OS / editor -------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
