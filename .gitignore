# --- secrets: never tracked -------------------------------------------------
.env
.env.*
!.env.example
!frontend/.env.development
!frontend/.env.production.example
*.key
*.pem
*credentials*
.aws/
aws.config

# --- data: generated/real data never belongs in git -------------------------
# reproduce locally with: python -m aayai.datagen (seeded, deterministic)
# anchored to the repo root for the same reason as /model/ below
/data/
*.csv
*.parquet

# --- model artifacts ---------------------------------------------------------
# ignore generated artifacts, but TRACK the small trained model (~270 KB) so the
# deployed API can score uploaded batches. /model/* (not model/) keeps this from
# shadowing src/aayai/model, the source package.
/model/*
!/model/aayai_model.ubj
!/model/feature_meta.json
*.joblib
*.pkl

# --- python cruft ------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- local infra state (can embed secrets — never push) ----------------------
*.tfstate
*.tfstate.backup
.terraform/
airflow/logs/
*.log

# --- frontend ----------------------------------------------------------------
node_modules/
frontend/dist/

# --- OS / editor -------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
